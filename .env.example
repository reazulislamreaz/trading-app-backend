# =================================================================
# SERVER CONFIGURATION
# =================================================================
PORT=5000
NODE_ENV=development

# Allowed Origins (comma-separated for multiple origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Backend IP (optional, defaults to 0.0.0.0)
BACKEND_IP=0.0.0.0

# =================================================================
# DATABASE CONFIGURATION
# =================================================================
# MongoDB connection string
# 
# LOCAL MONGODB (with authentication):
# Format: mongodb://username:password@localhost:27017/database_name?authSource=admin
# Example: mongodb://myuser:mypassword@localhost:27017/myapp?authSource=admin
#
# LOCAL MONGODB (without authentication - development only):
# Format: mongodb://localhost:27017/database_name
# Example: mongodb://localhost:27017/myapp
#
# MONGODB ATLAS (cloud):
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority
# Example: mongodb+srv://myuser:mypassword@cluster0.abc123.mongodb.net/myapp?retryWrites=true&w=majority
#
# IMPORTANT: Special characters in password must be URL-encoded
#   @ -> %40, : -> %3A, / -> %2F, # -> %23, ? -> %3F, & -> %26, = -> %3D
# Example: password "my@pass:word" becomes "my%40pass%3Aword"
#
DB_URL=mongodb://localhost:27017/your_database_name

# =================================================================
# JWT CONFIGURATION
# =================================================================
# ⚠️ IMPORTANT: All JWT secrets must be at least 32 characters long
# Generate secure random strings using:
#   - openssl rand -hex 32
#   - node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Access token - short-lived (for API requests)
ACCESS_TOKEN=your-super-secret-access-token-key-min-32-chars
ACCESS_EXPIRES=15m

# Refresh token - long-lived (for getting new access tokens)
REFRESH_TOKEN=your-super-secret-refresh-token-key-min-32-chars
REFRESH_EXPIRES=7d

# Reset token - for password reset (short-lived)
RESET_SECRET=your-super-secret-reset-token-key-min-32-chars
RESET_EXPIRES=10m

# Verification token - for email verification (short-lived)
VERIFIED_TOKEN=your-super-secret-verification-token-key-32-chars

# Frontend URL (for redirects and CORS)
FRONT_END_URL=http://localhost:3000

# =================================================================
# EMAIL CONFIGURATION
# =================================================================
# Gmail SMTP (recommended for development)
# 1. Enable 2FA on your Google account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use the App Password below

APP_USER_EMAIL=your_email@gmail.com
APP_PASSWORD=your_app_specific_password

# Custom SMTP (optional - uncomment to use custom SMTP)
# SMTP_HOST=smtp.yourdomain.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_FROM_EMAIL=noreply@yourdomain.com

# =================================================================
# SECURITY CONFIGURATION
# =================================================================
# Bcrypt salt rounds (higher = more secure but slower)
# Recommended: 10-12 for development, 12-14 for production
BCRYPT_SALT_ROUNDS=12

# =================================================================
# CLOUDINARY CONFIGURATION (File Upload)
# =================================================================
# Get your credentials from: https://cloudinary.com/console
CLOUD_NAME=your_cloud_name
CLOUD_API_KEY=your_cloud_api_key
CLOUD_API_SECRET=your_cloud_api_secret

# =================================================================
# AWS S3 CONFIGURATION (Optional - for file upload)
# =================================================================
# Get your credentials from AWS IAM Console
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_BUCKET_NAME=your_bucket_name

# =================================================================
# SEED ADMIN CONFIGURATION (Optional - for initial admin user)
# =================================================================
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminSecurePass123!

{
  "name": "trading-app-backend",
  "version": "2.0.0",
  "description": "Production-ready Express + TypeScript + MongoDB boilerplate with CI/CD, Docker, and VPS deployment",
  "main": "dist/server.js",
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "seed": "ts-node scripts/seed.ts",
    "seed:production": "NODE_ENV=production ts-node scripts/seed.ts",
    "db:reset": "ts-node scripts/seed.ts --reset"
  },
  "keywords": [
    "express",
    "mongoose",
    "typescript",
    "mongodb",
    "api",
    "boilerplate",
    "docker",
    "ci-cd",
    "production-ready",
    "vps-deployment",
    "authentication",
    "2fa",
    "jwt",
    "swagger"
  ],
  "author": "Reazul Islam Reaz <Backend Engineer>",
  "license": "ISC",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/reazulislamreaz/modular-backend-boilerplate.git"
  },
  "bugs": {
    "url": "https://github.com/reazulislamreaz/modular-backend-boilerplate/issues"
  },
  "homepage": "https://github.com/reazulislamreaz/modular-backend-boilerplate#readme",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1021.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.7.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "http-status": "^2.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.20.0",
    "mongoose": "^8.19.1",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.9",
    "otpauth": "^9.5.0",
    "stripe": "^22.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.8.1",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.2",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
